{
  "name": "botchat-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names \"nextjs,socket\" --prefix-colors \"blue,green\" \"next dev\" \"node ../socket-server/server.js\"",
    "dev:admin": "dotenv -e .env.admin -- next dev --port 3000",
    "dev:reseller": "dotenv -e .env.reseller -- next dev --port 3001",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query": "^5.100.14",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.18.0",
    "framer-motion": "^12.34.3",
    "gsap": "^3.14.2",
    "laravel-echo": "^2.3.4",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pusher-js": "^8.5.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-redux": "^9.2.0",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "typescript": "^5"
  }
